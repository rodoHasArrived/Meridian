{
  "name": "Market Data Collector",
  "image": "mcr.microsoft.com/devcontainers/dotnet:9.0",

  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    },
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.12"
    }
  },

  "containerEnv": {
    "DOTNET_SKIP_FIRST_TIME_EXPERIENCE": "1",
    "DOTNET_NOLOGO": "true",
    "DOTNET_CLI_TELEMETRY_OPTOUT": "1",
    "DOTNET_GENERATE_ASPNET_CERTIFICATE": "false"
  },

  "onCreateCommand": "dotnet restore MarketDataCollector.sln /p:EnableWindowsTargeting=true && dotnet build MarketDataCollector.sln -c Release --no-restore /p:EnableWindowsTargeting=true && npm ci",

  "postCreateCommand": "cp -n config/appsettings.sample.json config/appsettings.json 2>/dev/null || true",

  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": {
      "label": "Web Dashboard",
      "onAutoForward": "notify"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csdevkit",
        "ms-dotnettools.csharp",
        "ionide.ionide-fsharp",
        "ms-python.python",
        "editorconfig.editorconfig",
        "DavidAnson.vscode-markdownlint",
        "eamodio.gitlens"
      ],
      "settings": {
        "dotnet.defaultSolution": "MarketDataCollector.sln",
        "omnisharp.enableRoslynAnalyzers": true,
        "editor.formatOnSave": true,
        "files.trimTrailingWhitespace": true
      }
    }
  }
}
