<Page x:Class="MarketDataCollector.Wpf.Views.DifferentiatorsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignHeight="1200" d:DesignWidth="1300"
      Background="{DynamicResource ConsoleBackgroundDarkBrush}">

    <Page.Resources>

        <!-- Comparison table header cell -->
        <Style x:Key="CompHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource ConsoleTextSecondaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Padding" Value="8,6" />
        </Style>

        <!-- Comparison table data cell -->
        <Style x:Key="CompCellStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Padding" Value="8,8" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <!-- MDC win cell — green text -->
        <Style x:Key="CompCellWinStyle" TargetType="TextBlock" BasedOn="{StaticResource CompCellStyle}">
            <Setter Property="Foreground" Value="{StaticResource SuccessColorBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <!-- Non-MDC cell — muted text -->
        <Style x:Key="CompCellLossStyle" TargetType="TextBlock" BasedOn="{StaticResource CompCellStyle}">
            <Setter Property="Foreground" Value="{StaticResource ConsoleTextMutedBrush}" />
        </Style>

        <!-- Row separator line -->
        <Style x:Key="RowSeparatorStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="{StaticResource ConsoleBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Margin" Value="0" />
        </Style>

    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel MaxWidth="1300">

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- HERO HEADER                                                    -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <Border Background="{StaticResource ConsoleBackgroundMediumBrush}"
                    BorderBrush="{StaticResource ConsoleBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="32,28"
                    Margin="0,0,0,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="&#xE9D9;"
                                       FontFamily="{StaticResource SymbolThemeFontFamily}"
                                       FontSize="32"
                                       Foreground="{StaticResource InfoColorBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="Why Market Data Collector?"
                                       Style="{StaticResource PageTitleStyle}"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock TextWrapping="Wrap"
                                   MaxWidth="720"
                                   Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                   FontSize="14"
                                   LineHeight="22">
                            MDC is the only open-source market data collector that combines self-hosted deployment,
                            multi-provider failover, and institutional-grade data quality guarantees — at $0/month,
                            regardless of how many symbols you collect.
                        </TextBlock>
                    </StackPanel>

                    <!-- Moat badges (top-right) -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="32,0,0,0">
                        <Border Background="{StaticResource ConsoleAccentGreenAlpha20Brush}"
                                BorderBrush="{StaticResource SuccessColorBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Padding="14,8" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE72E;"
                                           FontFamily="{StaticResource SymbolThemeFontFamily}"
                                           FontSize="14" Foreground="{StaticResource SuccessColorBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="Self-Hosted"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource SuccessColorBrush}"
                                           Margin="8,0,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource ConsoleAccentBlueAlpha20Brush}"
                                BorderBrush="{StaticResource InfoColorBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Padding="14,8" Margin="0,0,0,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE968;"
                                           FontFamily="{StaticResource SymbolThemeFontFamily}"
                                           FontSize="14" Foreground="{StaticResource InfoColorBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="Multi-Provider"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource InfoColorBrush}"
                                           Margin="8,0,0,0" />
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource ConsoleAccentPurpleAlpha10Brush}"
                                BorderBrush="{StaticResource AccentPurpleBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Padding="14,8">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8A5;"
                                           FontFamily="{StaticResource SymbolThemeFontFamily}"
                                           FontSize="14" Foreground="{StaticResource AccentPurpleBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="Data Provenance"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource AccentPurpleBrush}"
                                           Margin="8,0,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- COST CALCULATOR                                                -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,24">
                <StackPanel>
                    <!-- Card Header -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="&#xE8C7;"
                                   FontFamily="{StaticResource SymbolThemeFontFamily}"
                                   FontSize="20" Foreground="{StaticResource SuccessColorBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="Cost Calculator"
                                   Style="{StaticResource CardHeaderStyle}"
                                   Margin="10,0,0,0" />
                    </StackPanel>
                    <TextBlock Text="See your annual savings vs. paid alternatives — MDC is always free, at any scale."
                               Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                               Margin="0,0,0,20" />

                    <!-- Symbol count slider -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="80" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Symbols to collect"
                                   Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                   VerticalAlignment="Center" />
                        <Slider Grid.Column="1"
                                Minimum="10" Maximum="5000"
                                Value="{Binding SymbolCount, UpdateSourceTrigger=PropertyChanged}"
                                TickFrequency="100"
                                IsSnapToTickEnabled="False"
                                VerticalAlignment="Center"
                                Margin="16,0" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding SymbolCount}"
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Right" />
                    </Grid>

                    <!-- Cost comparison row -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- MDC -->
                        <Border Grid.Column="0"
                                Background="{StaticResource ConsoleAccentGreenAlpha20Brush}"
                                BorderBrush="{StaticResource SuccessColorBrush}"
                                BorderThickness="2" CornerRadius="8" Padding="16,14">
                            <StackPanel>
                                <TextBlock Text="Market Data Collector"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource SuccessColorBrush}"
                                           Margin="0,0,0,6" />
                                <TextBlock Text="{Binding MdcMonthlyCostText}"
                                           FontSize="22" FontWeight="Bold"
                                           Foreground="{StaticResource SuccessColorBrush}" />
                                <TextBlock Text="{Binding AnnualSavingsVsPolygonText}"
                                           FontSize="11"
                                           Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>

                        <!-- Polygon -->
                        <Border Grid.Column="2"
                                Background="{StaticResource ConsoleBackgroundLightBrush}"
                                BorderBrush="{StaticResource ConsoleBorderBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="16,14">
                            <StackPanel>
                                <TextBlock Text="Polygon.io"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                           Margin="0,0,0,6" />
                                <TextBlock Text="{Binding PolygonMonthlyCostText}"
                                           FontSize="22" FontWeight="Bold"
                                           Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                <TextBlock Text="Developer plan (unlimited symbols)"
                                           FontSize="11"
                                           Foreground="{StaticResource ConsoleTextMutedBrush}"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>

                        <!-- Databento -->
                        <Border Grid.Column="4"
                                Background="{StaticResource ConsoleBackgroundLightBrush}"
                                BorderBrush="{StaticResource ConsoleBorderBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="16,14">
                            <StackPanel>
                                <TextBlock Text="Databento"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                           Margin="0,0,0,6" />
                                <TextBlock Text="{Binding DatabentoMonthlyCostText}"
                                           FontSize="22" FontWeight="Bold"
                                           Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                <TextBlock Text="{Binding AnnualSavingsVsDatabentoText}"
                                           FontSize="11"
                                           Foreground="{StaticResource ConsoleTextMutedBrush}"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>

                        <!-- Bloomberg -->
                        <Border Grid.Column="6"
                                Background="{StaticResource ConsoleBackgroundLightBrush}"
                                BorderBrush="{StaticResource ConsoleBorderBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="16,14">
                            <StackPanel>
                                <TextBlock Text="Bloomberg Terminal"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                           Margin="0,0,0,6" />
                                <TextBlock Text="{Binding BloombergMonthlyCostText}"
                                           FontSize="22" FontWeight="Bold"
                                           Foreground="{StaticResource ConsoleTextMutedBrush}" />
                                <TextBlock Text="Per user / month"
                                           FontSize="11"
                                           Foreground="{StaticResource ConsoleTextMutedBrush}"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Savings summary banner -->
                    <Border Background="{StaticResource ConsoleAccentGreenAlpha10Brush}"
                            BorderBrush="{StaticResource SuccessColorBrush}"
                            BorderThickness="1" CornerRadius="6"
                            Padding="16,12" Margin="0,16,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE73E;"
                                       FontFamily="{StaticResource SymbolThemeFontFamily}"
                                       FontSize="16" Foreground="{StaticResource SuccessColorBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding SavingsLabelText}"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource SuccessColorBrush}"
                                       Margin="10,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- DIFFERENTIATOR CARDS (2-column grid)                          -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <TextBlock Text="PLATFORM DIFFERENTIATORS"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{StaticResource ConsoleTextMutedBrush}"
                       Margin="0,0,0,12" />

            <ItemsControl ItemsSource="{Binding DifferentiatorCards}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="2" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,8,8" Padding="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="8" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="12" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Icon + Title -->
                                <StackPanel Grid.Row="0" Orientation="Horizontal">
                                    <Border Width="36" Height="36" CornerRadius="6"
                                            Margin="0,0,12,0" VerticalAlignment="Top">
                                        <Border.Background>
                                            <SolidColorBrush Color="{Binding IconColorHex}" Opacity="0.15" />
                                        </Border.Background>
                                        <TextBlock Text="{Binding Icon}"
                                                   FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                   FontSize="18"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Foreground>
                                                <SolidColorBrush Color="{Binding IconColorHex}" />
                                            </TextBlock.Foreground>
                                        </TextBlock>
                                    </Border>
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                               VerticalAlignment="Center"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <!-- Description -->
                                <TextBlock Grid.Row="2"
                                           Text="{Binding Description}"
                                           FontSize="13"
                                           Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           LineHeight="20" />

                                <!-- Badge -->
                                <Border Grid.Row="4"
                                        CornerRadius="4" Padding="8,4"
                                        HorizontalAlignment="Left">
                                    <Border.Background>
                                        <SolidColorBrush Color="{Binding BadgeColorHex}" Opacity="0.15" />
                                    </Border.Background>
                                    <TextBlock Text="{Binding Badge}"
                                               FontSize="11" FontWeight="SemiBold"
                                               FontFamily="Consolas">
                                        <TextBlock.Foreground>
                                            <SolidColorBrush Color="{Binding BadgeColorHex}" />
                                        </TextBlock.Foreground>
                                    </TextBlock>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- FEATURE COMPARISON TABLE                                       -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <TextBlock Text="FEATURE COMPARISON"
                       FontSize="11" FontWeight="SemiBold"
                       Foreground="{StaticResource ConsoleTextMutedBrush}"
                       Margin="0,16,0,12" />

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,24">
                <StackPanel>
                    <!-- Table header -->
                    <Border Style="{StaticResource RowSeparatorStyle}"
                            Background="{StaticResource ConsoleBackgroundLightBrush}"
                            CornerRadius="4,4,0,0" Padding="4,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2.2*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Feature" Style="{StaticResource CompHeaderStyle}" />
                            <TextBlock Grid.Column="1" Text="MDC" Style="{StaticResource CompHeaderStyle}"
                                       Foreground="{StaticResource SuccessColorBrush}" />
                            <TextBlock Grid.Column="2" Text="Polygon" Style="{StaticResource CompHeaderStyle}" />
                            <TextBlock Grid.Column="3" Text="Databento" Style="{StaticResource CompHeaderStyle}" />
                            <TextBlock Grid.Column="4" Text="Bloomberg" Style="{StaticResource CompHeaderStyle}" />
                        </Grid>
                    </Border>

                    <!-- Table rows -->
                    <ItemsControl ItemsSource="{Binding ComparisonRows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource RowSeparatorStyle}" Padding="4,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2.2*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                            <ColumnDefinition Width="1*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Feature}"
                                                   Style="{StaticResource CompCellStyle}"
                                                   Foreground="{StaticResource ConsoleTextPrimaryBrush}" />
                                        <TextBlock Grid.Column="1" Text="{Binding MdcValue}"
                                                   Style="{StaticResource CompCellWinStyle}" />
                                        <TextBlock Grid.Column="2" Text="{Binding PolygonValue}"
                                                   Style="{StaticResource CompCellLossStyle}" />
                                        <TextBlock Grid.Column="3" Text="{Binding DatabentoValue}"
                                                   Style="{StaticResource CompCellLossStyle}" />
                                        <TextBlock Grid.Column="4" Text="{Binding BloombergValue}"
                                                   Style="{StaticResource CompCellLossStyle}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════════ -->
            <!-- ACADEMIC POSITIONING                                           -->
            <!-- ═══════════════════════════════════════════════════════════════ -->
            <Border Background="{StaticResource ConsoleAccentPurpleAlpha10Brush}"
                    BorderBrush="{StaticResource AccentPurpleBrush}"
                    BorderThickness="1" CornerRadius="8"
                    Padding="28,22" Margin="0,0,0,24">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="&#xE8A5;"
                                   FontFamily="{StaticResource SymbolThemeFontFamily}"
                                   FontSize="20" Foreground="{StaticResource AccentPurpleBrush}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="For Academic Researchers"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                   Margin="10,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Pull quote -->
                    <Border BorderBrush="{StaticResource AccentPurpleBrush}"
                            BorderThickness="3,0,0,0"
                            Padding="16,4" Margin="0,0,0,16">
                        <TextBlock TextWrapping="Wrap"
                                   FontSize="14" FontStyle="Italic"
                                   Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                   LineHeight="24">
                            MDC is the first open-source market data collector that produces reproducible,
                            version-annotated, anomaly-tagged, cross-provider-reconciled tick data
                            suitable for academic publication.
                        </TextBlock>
                    </Border>

                    <!-- Capability bullets -->
                    <UniformGrid Columns="3">
                        <StackPanel Margin="0,0,16,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="&#xE73E;"
                                           FontFamily="{StaticResource SymbolThemeFontFamily}"
                                           FontSize="13" Foreground="{StaticResource SuccessColorBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="Versioned Canonicalization"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                           Margin="6,0,0,0" />
                            </StackPanel>
                            <TextBlock Text="Every tick carries a CanonicalizationVersion byte. Normalization rules are auditable and replayable across datasets."
                                       FontSize="12"
                                       Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel Margin="0,0,16,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="&#xE73E;"
                                           FontFamily="{StaticResource SymbolThemeFontFamily}"
                                           FontSize="13" Foreground="{StaticResource SuccessColorBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="Anomaly Events in Stream"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                           Margin="6,0,0,0" />
                            </StackPanel>
                            <TextBlock Text="PriceSpike, SequenceGap, and CrossedMarket events are typed, stored, and queryable alongside regular ticks in the same timeline."
                                       FontSize="12"
                                       Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <TextBlock Text="&#xE73E;"
                                           FontFamily="{StaticResource SymbolThemeFontFamily}"
                                           FontSize="13" Foreground="{StaticResource SuccessColorBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="Cross-Provider Reconciliation"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource ConsoleTextPrimaryBrush}"
                                           Margin="6,0,0,0" />
                            </StackPanel>
                            <TextBlock Text="PersistentDedupLedger resolves tick identity across providers. Data completeness and duplication rates are queryable per symbol-day."
                                       FontSize="12"
                                       Foreground="{StaticResource ConsoleTextSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </UniformGrid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
